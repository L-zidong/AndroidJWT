# 复制为 local.properties 后填写（local.properties 不要提交 Git）

sdk.dir=YOUR_ANDROID_SDK_PATH

# ---------- 和风天气 QWeather（JWT / Ed25519，可选）----------
# API Host：控制台 → 设置 → 查看（形如 xxxxx.qweatherapi.com，不要带 https://）
qweather.api.host=YOUR_API_HOST.qweatherapi.com
# 项目 ID（JWT Payload 的 sub）
qweather.project.id=YOUR_PROJECT_ID
# 凭据 ID（JWT Header 的 kid）
qweather.credential.id=YOUR_CREDENTIAL_ID
